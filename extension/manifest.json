{
  "key": "",
  "manifest_version": 3,
  "name": "Oryx Solver - An Ai Homework Helper",
  "version": "0.1",
  "description": "an ai homework helper",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src http://localhost:* http://127.0.0.1:* https://objizntvrmckzdpdgqjo.supabase.co https://*.sentry.io ;"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/cropOverlay.ts",
        "src/content/domExtractor.ts"
      ],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/inlineInjector.ts"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "tabs",
    "scripting"
  ], 
  "host_permissions": [
    "<all_urls>",
    "https://*.supabase.co/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*.png",
        "assets/katex/*",
        "assets/katex/fonts/*"
      ],
      "matches": ["<all_urls>"]
    },
    {
      "resources": [
        "src/sidepanel/index.html"
      ],
      "matches": [
        "https://*.supabase.co/*",
        "https://accounts.google.com/*"
      ]
    }
  ]
}
