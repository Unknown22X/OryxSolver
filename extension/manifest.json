{
  "key": "",
  "manifest_version": 3,
  "name": "Oryx Solver - An Ai Homework Helper",
  "version": "0.1",
  "description": "an ai homework helper",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "34": "icons/34.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {},
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src http://localhost:* http://127.0.0.1:* https://objizntvrmckzdpdgqjo.supabase.co https://*.sentry.io ;"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://docs.google.com/forms/*",
        "https://forms.office.com/*",
        "https://forms.microsoft.com/*",
        "https://*.instructure.com/*",
        "https://1600.lol/*",
        "https://oneprep.xyz/*",
        "https://oneprep.com/*",
        "https://oneprep.io/*",
        "https://oneprep.app/*",
        "https://cracksat.net/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "src/content/cropOverlay.ts",
        "src/content/domExtractor.ts",
        "src/content/inlineInjector.ts"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "tabs",
    "scripting"
  ], 
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*.supabase.co/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*.png",
        "assets/katex/*",
        "assets/katex/fonts/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
